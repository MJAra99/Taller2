# -----------------------------------------------------------------------------
# Inspección de tipos y NAs
# -----------------------------------------------------------------------------
a <- 10
b <- "11"
typeof(a)       # "double" si no usas sufijo L
class(b)        # "character"
is.logical(TRUE)
is.character(b)
d <- NA
is.na(d)
num1 <- "8"
num2 <- "10"
class(num1)
as.numeric(num1) + as.numeric(num2) # 18
num1+num2
num3 <- "8.3"
num3 <- as.numeric(num3)
typeof(num3)                        # "double"
# Coerción de numeric -> character
num1 <- 8
class(num1)         # "numeric" (double)
num1 <- as.character(num1)
class(num1)         # "character"
# 1) Aritmética vectorizada (elemento a elemento)
x <- c(1, 2, 3, 4)
y <- c(10, 20, 30, 40)
x + y
x - y
x * y
x / y
x ^ 2
# 1) Aritmética vectorizada (elemento a elemento)
x <- c(1, 2, 3, 4)
y <- c(10, 20, 30, 40,50)
x + y
x <- c(1, 2, 3, 4,5)
y <- c(10, 20, 30, 40)
x + y
x ^ y
x <- c(1, 2, 3, 4)
y <- c(10, 20, 30, 40)
x ^ y
z <- c(100, 200)
x + z  # = c(1+100, 2+200, 3+100, 4+200)
# 3) Comparaciones y operadores lógicos (elemento a elemento)
x > 2
x == c(1, 5, 3, 9)
x != 2
(x > 2) & (y <= 30)   # AND
(x > 2) | (y <= 30)   # OR
!(x > 2)              # Negación
x > c(2,1,2,3)
x > y
x > c(2,1,5)
# 4) Tratamiento de NA en operaciones
val <- c(1, 2, NA, 4)
sum(val)               # NA
sum(val, na.rm = TRUE) # 7 (ignora NA)
# 5) Strings y concatenación (no existe “suma” de caracteres)
s1 <- "Hola"; s2 <- "Mundo"
paste(s1, s2)           # "Hola Mundo"
paste0(s1, "_", s2)     # "Hola_Mundo"
x <- "1"
y <- "8"
z <- paste(x,y)
z <- as.numeric(z)
typeof(z)
x <- "1"
y <- "8"
z <- paste(x,y,sep="")
z <- as.numeric(z)
typeof(z)
#Uniforme
runif(100,min=0, max=100)
#Uniforme
runif(100,0,100)
rnornm(100,mean=1,sd=2)
rnorm(100,mean=1,sd=2)
