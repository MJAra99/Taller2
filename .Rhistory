library_sizes <- sapply(installed.packages()[, "Package"], function(pkg) {
path <- find.package(pkg)
size <- sum(file.info(list.files(path, recursive = TRUE, full.names = TRUE))$size)
size
})
sort(round(library_sizes / 1024^2, 2))
total_size <- sum(library_sizes) / 1024^2
paste("Total:", round(total_size, 2), "MB")
